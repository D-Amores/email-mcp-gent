# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | ollama | deepseek | openai
LLM_PROVIDER=gemini

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── Ollama (local, no key needed) ────────────────────────────────────────────
OLLAMA_MODEL=qwen3.5:9b

# ─── DeepSeek ─────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ─── OpenAI (futuro) ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
